TAVILY_API_KEY=
DATABASE_URL=postgresql+psycopg://resource_agent:resource_agent@postgres:5432/resource_agent
DATABASE_READONLY_URL=postgresql+psycopg://resource_reader:resource_reader@postgres:5432/resource_agent
REDIS_URL=redis://redis:6379/0
MCP_SERVER_URL=http://mcp-server:8001/mcp
AUDIO_DIR=/data/audio
SEED_DIR=/app/seed
REPORT_TEMPLATE=/app/backend/templates/report.md.j2
WHISPER_MODEL_PATH=/data/models/faster-whisper-small
VECTOR_SIMILARITY_THRESHOLD=0.18
MODEL_PROVIDER=OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://vftsub.vf-tech.cn
LLM_ENABLED=true
LLM_MODEL=gpt-5.5
LLM_REVIEW_MODEL=gpt-5.5
LLM_REASONING_EFFORT=xhigh
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=1
LLM_DISABLE_RESPONSE_STORAGE=true
LLM_WEB_IDENTITY_THRESHOLD=0.80
LLM_PROJECT_CONFIDENCE_THRESHOLD=0.60
LLM_ANALYSIS_CONFIDENCE_THRESHOLD=0.60
LLM_SAFETY_SALT=
PROMPT_DIR=/app/backend/prompts
DETAILED_REPORT_TEMPLATE=/app/backend/templates/detailed_report.md.j2
ACTION_BRIEF_TEMPLATE=/app/backend/templates/action_brief.md.j2
